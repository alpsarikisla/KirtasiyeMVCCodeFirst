@model IEnumerable<YeniKitapKirtasiyeWebApp.Models.Category>

@{
    ViewBag.Title = "Index";
    Layout = "~/Areas/ManagerPanel/Views/Shared/_LayoutPage1.cshtml";
}

<div class="card">
    <div class="card-header">
        <div class="card-title">
            <h2>Kategori Listesi</h2>
            <a href="@Url.Action("Create","Category")" class="title-button"> + Yeni Kategori </a>
        </div>
    </div>
    <div class="card-body">
        <table class="table" cellpadding="0" cellspacing="0">
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.ID)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Name)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.IsActive)
                </th>
                <th>
                   Seçenekler
                </th>
            </tr>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @item.ID
                    </td>
                    <td>
                        @item.Name
                    </td>
                    <td>
                        @if (item.IsActive)
                        {
                            <label style="color:lightseagreen">Aktif Kategori</label>
                        }
                        else
                        {
                            <label style="color:silver">Pasif Kategori</label>
                        }
                    </td>
                    <td>
                        <a href="@Url.Action("Edit","Category", new {id = item.ID})" class="tablebutton duzenlebuton">Düzenle</a>
                        <a href="@Url.Action("Delete","Category", new {id = item.ID})" class="tablebutton silbuton">Sil</a>
                    </td>
                </tr>
            }

        </table>
    </div>
    <div class="card-footer">
        <label>@Model.Count() adet kategori bulunmaktadır</label>
    </div>
</div>


