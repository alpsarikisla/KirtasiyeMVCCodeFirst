@using YeniKitapKirtasiyeWebApp.Models
@model IEnumerable<CartItem>
@{
    ViewBag.Title = "Sepet";
    Layout = "~/Views/Shared/_LayoutPage1.cshtml";
}

@if (Model.Count() != 0)
{
    <table  class="sepettablo" cellpadding="0" cellspacing="0">
        <tr>
            <th>No</th>
            <th>Ürün</th>
            <th>Fiyat</th>
            <th>Adet</th>
        </tr>
        @foreach (CartItem item in Model)
        {
            <tr class="eleman">
                <td>@item.ID</td>
                <td>@item.Name</td>
                <td>@item.Price ₺</td>
                <td>
                    <a href="@Url.Action("Azalt","Urun", new {id=item.ID})">-</a>
                    @item.Quantity
                    <a href="@Url.Action("Arttir","Urun", new {id=item.ID})">+</a>
                </td>
            </tr>
        }
        <tr>
            <td colspan="2" style="text-align:right; margin-right:10px;"><b>Toplam</b> </td>
            <td colspan="2" style="margin-left:10px;">
                <b>@Model.Sum(x => (x.Price * x.Quantity)) ₺</b>
            </td>
        </tr>
        <tr>
            <td colspan="4" style="text-align:right">
                <a href="@Url.Action("sepetiBosalt","Urun")">Sepeti Boşalt</a>
            </td>
        </tr>
    </table>
}
else
{
    <p>Sepetiniz Boş</p>
}

